---
const { title, zh, en } = Astro.props;
---
<main class="section">
  <article class="empty-state">
    <p class="meta-line">{title}</p>
    <h2>暂无内容 / No content yet</h2>
    <div class="bilingual">
      <p>{zh}</p>
      <p>{en}</p>
    </div>
    <div class="mf-actions">
      <a class="button dark" href="/">返回首页 / Back home</a>
      <a class="button dark" href="/billloopr/">BillLoopr</a>
    </div>
  </article>
</main>
