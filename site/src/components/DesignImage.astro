---
const {
  baseName,
  alt,
  caption,
  fullHref,
  width,
  height,
  priority = false,
  portrait = false,
  widths = [640, 1200],
  sizes = '(max-width: 820px) calc(100vw - 32px), 1180px',
} = Astro.props;

const imageRoot = '/assets/img/monster-sun-station-design';
const smallestWidth = widths.at(0);
const webpSourceSet = widths.map((item) => `${imageRoot}/${baseName}-${item}.webp ${item}w`).join(', ');
const avifSourceSet = widths.map((item) => `${imageRoot}/${baseName}-${item}.avif ${item}w`).join(', ');
---

<figure class:list={['trail-figure', portrait && 'trail-figure--portrait']}>
  <a href={`${imageRoot}/${fullHref}`} target="_blank" rel="noreferrer" aria-label={`${caption}，查看大图`}>
    <picture>
      <source type="image/avif" srcset={avifSourceSet} sizes={sizes} />
      <source type="image/webp" srcset={webpSourceSet} sizes={sizes} />
      <img
        src={`${imageRoot}/${baseName}-${smallestWidth}.webp`}
        srcset={webpSourceSet}
        sizes={sizes}
        alt={alt}
        width={width}
        height={height}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : undefined}
      />
    </picture>
  </a>
  <figcaption>{caption}</figcaption>
</figure>
