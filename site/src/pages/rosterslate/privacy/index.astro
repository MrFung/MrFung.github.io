---
import BaseLayout from "../../../components/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";

const sections = [
  {
    title: "应用内存储的信息 / Information stored in the app",
    zh: "RosterSlate 不需要账号即可使用。App 可能会在你的设备上保存你输入的工作单位、人员、班次类型、排班记录、提醒规则、备注、偏好设置和相关配置。",
    en: "RosterSlate is designed to work without an account. The app may store information you enter on your device, including workplaces, people, shift types, shift records, reminder rules, notes, app preferences, and related settings."
  },
  {
    title: "本地存储和 iCloud / Local storage and iCloud",
    zh: "你的 App 数据主要使用 Apple 平台存储技术保存在设备本地。如果你启用 iCloud 私密同步，Apple 会通过你的私人 iCloud 账号同步数据。RosterSlate 不运营自己的服务器来同步或收集你的排班记录。",
    en: "Your app data is stored locally on your device using Apple platform storage technologies. If you enable private iCloud sync, Apple syncs data through your private iCloud account. RosterSlate does not operate its own server for syncing or collecting your roster records."
  },
  {
    title: "相机、图片和文字识别 / Camera, photos, and text recognition",
    zh: "当你主动导入班表图片或拍照识别班表时，RosterSlate 会使用系统相机、照片选择器、文件选择器和设备端文字识别能力。识别结果会显示给你确认后再写入排班记录。",
    en: "When you choose to import a roster image or capture a roster photo, RosterSlate uses system camera, photo picker, file picker, and on-device text recognition features. Recognized results are shown for your review before they are saved as roster records."
  },
  {
    title: "日历和通知 / Calendar and notifications",
    zh: "RosterSlate 可在你授权后发送上班提醒，并可在你开启设置后把确认的班次写入 Apple Calendar。通知和日历权限由系统控制，你可以随时在系统设置中调整。",
    en: "RosterSlate may send shift reminders after you allow notifications, and may add confirmed shifts to Apple Calendar after you enable that setting. Notification and calendar permissions are controlled by the system and can be changed in system settings."
  },
  {
    title: "无跟踪和广告 / No tracking or advertising",
    zh: "RosterSlate 不展示第三方广告，不接入第三方分析 SDK，也不会跨 App 或网站跟踪你。产品诊断默认关闭。",
    en: "RosterSlate does not show third-party ads, does not use third-party analytics SDKs, and does not track you across apps or websites. Product diagnostics are off by default."
  },
  {
    title: "分享和导出 / Sharing and exports",
    zh: "当你主动导出、分享、复制或发送排班信息时，所选信息可能会通过你选择的目标离开 App，例如邮件、文件、信息或其它 App。这些目标由你和相关服务提供商控制。",
    en: "When you choose to export, share, copy, or send roster information, the selected information may leave the app through the destination you choose, such as Mail, Files, Messages, or another app. Those destinations are controlled by you and by the relevant service providers."
  },
  {
    title: "支持请求 / Support requests",
    zh: "如果你通过邮件联系支持，我们可能会收到你的邮箱地址和你主动提供的内容。这些信息仅用于回复支持请求。",
    en: "If you contact support by email, we may receive your email address and any information you choose to include. This information is used only to respond to your support request."
  },
  {
    title: "非医疗软件 / Not medical software",
    zh: "RosterSlate 是通用排班工具，不是医疗软件。医疗、护理或值班模板只用于排班整理；App 不保存患者资料、诊疗记录、病历号、处方或医疗决策信息。",
    en: "RosterSlate is a general roster planning tool, not medical software. Medical, nursing, or on-call templates are only for organizing shifts; the app does not store patient records, clinical records, medical record numbers, prescriptions, or medical decision information."
  },
  {
    title: "删除数据 / Deleting data",
    zh: "你可以在 App 内通过可用的删除入口删除工作单位、人员、班次类型、排班记录、提醒规则和相关数据。你也可以通过删除 App 来移除本地保存的 App 数据。",
    en: "You can delete workplaces, people, shift types, shift records, reminder rules, and related data inside the app where deletion controls are available. You can also delete all locally stored app data by deleting the app from your device."
  },
  {
    title: "儿童 / Children",
    zh: "RosterSlate 不面向儿童，主要用于轮班工作者、兼职人员和排班管理场景。",
    en: "RosterSlate is not directed to children and is intended for shift workers, part-time workers, and roster planning use."
  },
  {
    title: "政策更新 / Changes to this policy",
    zh: "当 App 功能变化时，我们可能会更新本政策。发生重要更新时，页面顶部的生效日期会同步调整。",
    en: "We may update this policy when the app changes. The effective date above will be updated when material changes are made."
  }
];
---
<BaseLayout title="隐私政策 / Privacy Policy - RosterSlate" description="RosterSlate privacy policy in Chinese and English.">
  <Hero compact kicker="RosterSlate" title="隐私政策 / Privacy Policy" zh="生效日期：2026 年 7 月 11 日" en="Effective date: July 11, 2026" />
  <main class="section">
    <article class="prose-card content-stack">
      <div class="bilingual">
        <p>RosterSlate 是由 MrFung 开发的私密排班表与轮班提醒工具。本政策说明 App 会处理哪些信息以及如何使用这些信息。</p>
        <p>RosterSlate is a private roster and shift reminder app developed by MrFung. This policy explains what information the app handles and how it is used.</p>
      </div>
      {sections.map((section) => (
        <section class="callout">
          <h3>{section.title}</h3>
          <div class="bilingual">
            <p>{section.zh}</p>
            <p>{section.en}</p>
          </div>
        </section>
      ))}
      <section class="callout">
        <h3>联系 / Contact</h3>
        <div class="bilingual">
          <p>如果你有隐私问题，请联系：<a href="mailto:2578033436@qq.com">2578033436@qq.com</a></p>
          <p>If you have privacy questions, contact: <a href="mailto:2578033436@qq.com">2578033436@qq.com</a></p>
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
