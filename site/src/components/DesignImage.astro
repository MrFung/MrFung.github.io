---
const {
  baseName,
  alt,
  caption,
  fullHref,
  width,
  height,
  priority = false,
  portrait = false,
  widths = [640, 1200],
  sizes = '(max-width: 820px) calc(100vw - 32px), 1180px',
} = Astro.props;

const imageRoot = '/assets/img/monster-sun-station-design';
const largestWidth = widths.at(-1);
const sourceSet = widths.map((item) => `${imageRoot}/${baseName}-${item}.webp ${item}w`).join(', ');
---

<figure class:list={['trail-figure', portrait && 'trail-figure--portrait']}>
  <a href={`${imageRoot}/${fullHref}`} target="_blank" rel="noreferrer" aria-label={`${caption}，查看大图`}>
    <img
      src={`${imageRoot}/${baseName}-${largestWidth}.webp`}
      srcset={sourceSet}
      sizes={sizes}
      alt={alt}
      width={width}
      height={height}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'low'}
    />
  </a>
  <figcaption>{caption}</figcaption>
</figure>
