---
import BaseLayout from "../../components/BaseLayout.astro";
---
<BaseLayout title="应用 / Apps - MrFung" description="MrFung 的应用目录，集中展示应用介绍、隐私政策和支持入口。">
  <header class="page-intro">
    <div class="section">
      <p class="page-kicker">Apps</p>
      <h1>应用 / Apps</h1>
      <div class="bilingual intro-copy">
        <p>BillLoopr 与 RosterSlate 的产品页、隐私政策和支持入口。</p>
        <p>Product pages, privacy policies, and support links for BillLoopr and RosterSlate.</p>
      </div>
    </div>
  </header>

  <main>
    <section class="section">
      <div class="section-heading">
        <h2>应用目录 / App Directory</h2>
      </div>
      <div class="app-directory">
        <article class="app-card">
          <div class="app-card-main">
            <span class="lang-label">Billable Time</span>
            <h3>BillLoopr</h3>
            <div class="bilingual">
              <p>面向独立工作者的计费工时、项目记录和发票准备工具。</p>
              <p>Billable time tracking, project records, and invoice preparation for independent professionals.</p>
            </div>
          </div>
          <div class="app-link-grid">
            <a href="/billloopr/">
              <strong>产品页 / Product</strong>
              <span>功能介绍和公开入口</span>
            </a>
            <a href="/billloopr/privacy/">
              <strong>隐私政策 / Privacy</strong>
              <span>数据存储、导出和删除说明</span>
            </a>
            <a href="/billloopr/support/">
              <strong>支持页面 / Support</strong>
              <span>联系支持和常见帮助主题</span>
            </a>
          </div>
        </article>

        <article class="app-card">
          <div class="app-card-main">
            <span class="lang-label">Shift Planner</span>
            <h3>RosterSlate</h3>
            <div class="bilingual">
              <p>面向轮班工作者的私密排班表、同班人员和上班提醒工具。</p>
              <p>A private roster, coworker, and shift reminder planner for shift workers.</p>
            </div>
          </div>
          <div class="app-link-grid">
            <a href="/rosterslate/">
              <strong>产品页 / Product</strong>
              <span>功能介绍和公开入口</span>
            </a>
            <a href="/rosterslate/privacy/">
              <strong>隐私政策 / Privacy</strong>
              <span>本地存储、相机识别和数据删除说明</span>
            </a>
            <a href="/rosterslate/support/">
              <strong>支持页面 / Support</strong>
              <span>联系支持和常见帮助主题</span>
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
