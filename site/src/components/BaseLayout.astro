---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getMessages } from '../i18n/messages/index.mjs';
import { SUPPORTED_LOCALES, languageDefinition, localizedPath } from '../i18n/languages.mjs';

const {
  locale = 'en',
  routePath = Astro.url.pathname,
  title,
  description,
  legacy = !SUPPORTED_LOCALES.includes(Astro.url.pathname.split('/').filter(Boolean)[0]),
} = Astro.props;
const messages = getMessages(locale).site;
const language = languageDefinition(locale);
const pageTitle = title ?? messages.meta.title;
const pageDescription = description ?? messages.meta.description;
const canonical = new URL(localizedPath(locale, routePath), Astro.site);
---
<!doctype html>
<html lang={locale} dir={language.dir}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}>
    <link rel="canonical" href={canonical}>
    {SUPPORTED_LOCALES.map((code) => <link rel="alternate" hreflang={code} href={new URL(localizedPath(code, routePath), Astro.site)} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(localizedPath('en', routePath), Astro.site)}>
    <link rel="stylesheet" href="/assets/css/mrfung-site.css?v=20260711d">
    {legacy && (
      <script is:inline define:vars={{ routePath }}>
        const supported = ['en','zh-Hans','zh-Hant','ja','ko','es','fr','de','pt-BR','it','ru','ar'];
        const normalize = (value) => {
          if (!value) return null;
          const tag = value.replaceAll('_', '-');
          if (supported.includes(tag)) return tag;
          const lower = tag.toLowerCase();
          if (/^zh-(tw|hk|mo|hant)/.test(lower)) return 'zh-Hant';
          if (lower.startsWith('zh')) return 'zh-Hans';
          if (lower.startsWith('pt')) return 'pt-BR';
          return supported.find((code) => lower.startsWith(code.toLowerCase())) ?? null;
        };
        const saved = normalize(localStorage.getItem('mrfung.siteLanguage'));
        const browser = navigator.languages?.map(normalize).find(Boolean) ?? normalize(navigator.language);
        const target = `/${saved ?? browser ?? 'en'}${routePath}`.replace(/\/+/g, '/');
        window.location.replace(target.endsWith('/') ? target : `${target}/`);
      </script>
    )}
  </head>
  <body class="mf-static-page">
    <nav class="site-nav" aria-label={messages.nav.aria}>
      <div class="nav-inner">
        <div class="nav-links">
          <a href={localizedPath(locale, '/')}>{messages.nav.home}</a>
          <a href={localizedPath(locale, '/apps/')}>{messages.nav.apps}</a>
          <a href={localizedPath(locale, '/writing/')}>{messages.nav.writing}</a>
          <a href={localizedPath(locale, '/about/')}>{messages.nav.about}</a>
          <a href="mailto:2578033436@qq.com">{messages.nav.contact}</a>
        </div>
        <LanguageSwitcher {locale} {routePath} label={messages.language.label} />
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="footer-inner">
        <span>{messages.footer.copyright}</span>
        <span><a href={localizedPath(locale, '/apps/')}>{messages.footer.apps}</a> · <a href={localizedPath(locale, '/writing/')}>{messages.footer.writing}</a> · <a href={localizedPath(locale, '/about/')}>{messages.footer.about}</a> · <a href="mailto:2578033436@qq.com">{messages.footer.contact}</a></span>
      </div>
    </footer>
  </body>
</html>
