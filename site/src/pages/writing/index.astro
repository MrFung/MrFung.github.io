---
import BaseLayout from "../../components/BaseLayout.astro";
import { SNOW_FULL_TOWER_META } from "../../content/snowFullTower.mjs";
---
<BaseLayout title="文章 / Writing - MrFung" description="MrFung 的文章目录，记录全栈、AICoding、独立产品和运动实践。">
  <header class="page-intro">
    <div class="section">
      <p class="page-kicker">Writing</p>
      <h1>文章 / Writing</h1>
      <div class="bilingual intro-copy">
        <p>全栈、AICoding、独立产品和运动实践。</p>
        <p>Full-stack, AICoding, independent products, and endurance practice.</p>
      </div>
    </div>
  </header>

  <main>
    <section class="section">
      <div class="writing-list">
        <article class="article-card">
          <div>
            <span class="lang-label">诗歌 · Poetry</span>
            <h2>{SNOW_FULL_TOWER_META.title}</h2>
            <p>{SNOW_FULL_TOWER_META.summary}</p>
          </div>
          <a href={SNOW_FULL_TOWER_META.path}>
            阅读 / Read
          </a>
        </article>
        <article class="article-card">
          <div>
            <span class="lang-label">Technology · KMP</span>
            <h2>Kotlin Multiplatform 三端高频数据 Core：iOS、Android 与 HarmonyOS 的性能实测与工程选型</h2>
            <p>基于三端真机数据，比较原生、标准 KMP 与高频批量边界的延迟、吞吐、内存和长稳表现。</p>
          </div>
          <a href="/writing/kmp-three-platform-performance/">阅读 / Read</a>
        </article>
        <article class="article-card">
          <div>
            <span class="lang-label">Interior Design</span>
            <h2>怪兽小太阳驿站设计</h2>
            <p>把一座越野跑公司的办公地点，改造成兼具办公、会客、品牌展陈、赞助商接待与对外营业能力的山野会客厅。</p>
          </div>
          <a href="/writing/monster-sun-station-design/">阅读 / Read</a>
        </article>
        <article class="article-card">
          <div>
            <span class="lang-label">Profile</span>
            <h2>自我介绍：把工程、AICoding 和耐力运动放在一起</h2>
            <div class="bilingual">
              <p>我关注全栈开发、AICoding、独立产品，也把耐力运动里的节奏感带进产品打磨。</p>
              <p>I focus on full-stack development, AICoding, and independent products, with an endurance mindset shaped by sport.</p>
            </div>
          </div>
          <a href="/writing/self-introduction/">阅读 / Read</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
