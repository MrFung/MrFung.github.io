---
import BaseLayout from "../components/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import EmptyState from "../components/EmptyState.astro";
---
<BaseLayout title="标签 / Tags - MrFung">
  <Hero compact kicker="Writing Reset" title="标签 / Tags" zh="旧标签已清理，新的标签会跟随后续内容重新建立。" en="Old tags have been cleared. New tags will be rebuilt with future writing." />
  <EmptyState title="Tags" zh="暂无标签。" en="No tags yet." />
</BaseLayout>
