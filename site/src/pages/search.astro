---
import BaseLayout from "../components/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---
<BaseLayout title="搜索 / Search - MrFung">
  <Hero compact kicker="Search" title="搜索 / Search" zh="搜索当前公开站点内容。" en="Search the currently public pages on this site." />
  <main class="section">
    <article class="prose-card">
      <div class="bilingual">
        <p>旧博客已下线，因此搜索结果主要来自个人主页和 BillLoopr 支持/隐私页面。</p>
        <p>Older posts have been removed, so search results mainly come from the profile and BillLoopr support/privacy pages.</p>
      </div>
      <form class="mf-search-form" action="https://www.google.com/search" method="get" target="_blank">
        <input type="search" name="q" autocomplete="off" placeholder="搜索 / Search">
        <input type="hidden" name="sitesearch" value="www.mrfung.cn">
        <button type="submit">Search</button>
      </form>
    </article>
  </main>
</BaseLayout>
