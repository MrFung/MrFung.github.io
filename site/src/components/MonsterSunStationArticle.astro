const projectSummary = [
  '项目类型｜越野跑品牌综合空间',
  '设计状态｜最终方案·正式询价版',
  '使用规模｜11人协同办公',
  '改造原则｜保留固定墙体与既有结构',
];

const designRoutes = [
  ['公众到访', '沿街营业入口 → 日咖夜酒 → 山野会客厅 → 品牌展厅'],
  ['团队办公', '一层机动项目区 → 三级台阶 → 二层6个固定工位'],
  ['赞助商接待', '品牌正门 → 品牌前厅 → 台盆过道 → 赞助商会议室'],
];

const planningDrawings = [
  {
    baseName: 'drawing-02',
    alt: 'A-02一层家具与尺寸平面图',
    caption: 'A-02｜一层家具与尺寸平面图',
    fullHref: 'drawing-02-full.png',
  },
  {
    baseName: 'drawing-03',
    alt: 'A-03二层及阳台家具与尺寸平面图',
    caption: 'A-03｜二层及阳台家具与尺寸平面图',
    fullHref: 'drawing-03-full.png',
  },
];

const renders = [
  {
    baseName: 'render-cafe',
    alt: '日咖夜酒区最终室内效果图',
    caption: '日咖夜酒｜面向公众的咖啡、补给与夜间社交界面',
    width: 1667,
    height: 943,
  },
  {
    baseName: 'render-lounge',
    alt: '山野会客厅最终室内效果图',
    caption: '山野会客厅｜选手接待、发布分享与小型活动空间',
    width: 1086,
    height: 1448,
    portrait: true,
  },
  {
    baseName: 'render-exhibition',
    alt: '品牌展厅最终室内效果图',
    caption: '品牌展厅｜沿固定墙展开的赛事时间线与纪念展陈',
    width: 1086,
    height: 1448,
    portrait: true,
  },
  {
    baseName: 'render-project-office',
    alt: '机动项目区最终室内效果图',
    caption: '机动项目区｜5个返场工位与赛事协作信息墙',
    width: 1667,
    height: 943,
  },
  {
    baseName: 'render-front-hall',
    alt: '品牌前厅最终室内效果图',
    caption: '品牌前厅｜签到咨询、等候与双开门冰箱保留布置',
    width: 1448,
    height: 1086,
  },
  {
    baseName: 'render-meeting-room',
    alt: '赞助商会议室最终室内效果图',
    caption: '赞助商会议室｜8人舒适使用、10人峰值洽谈',
    width: 1668,
    height: 943,
  },
  {
    baseName: 'render-office-street',
    alt: '二楼背街侧办公室最终效果图',
    caption: '二楼背街侧办公室｜3个固定安静工位',
    width: 1668,
    height: 943,
  },
  {
    baseName: 'render-office-balcony',
    alt: '二楼阳台侧办公室最终效果图',
    caption: '二楼阳台侧办公室｜3个固定工位与管理协作区',
    width: 1667,
    height: 943,
  },
  {
    baseName: 'render-facade-arches',
    alt: '沿街四个拱形小门最终立面效果图',
    caption: '沿街四个拱形小门｜一处营业入口与三处连续展示橱窗',
    width: 1445,
    height: 1088,
  },
  {
    baseName: 'render-facade-main',
    alt: '品牌正门与二楼阳台最终立面效果图',
    caption: '品牌正门与二楼阳台｜形成远近两级品牌识别',
    width: 1445,
    height: 1089,
  },
];

const technicalDrawings = [
  ['drawing-04', 'A-04沿街主立面与门头设计图', 'A-04｜沿街主立面与门头设计图'],
  ['drawing-05', 'A-05机动项目区固定桌与地台节点详图', 'A-05｜机动项目区固定桌与地台节点详图'],
  ['drawing-06', 'A-06卫生间前厅与外置台盆节点详图', 'A-06｜卫生间前厅与外置台盆节点详图'],
  ['drawing-07', 'A-07一层天花与照明分区图', 'A-07｜一层天花与照明分区图'],
  ['drawing-08', 'A-08强弱电点位与设备回路图', 'A-08｜强弱电点位与设备回路图'],
  ['drawing-09', 'A-09品牌展厅立面与展柜节点详图', 'A-09｜品牌展厅立面与展柜节点详图'],
  ['drawing-10', 'A-10品牌前厅与日咖夜酒运营节点详图', 'A-10｜品牌前厅与日咖夜酒运营节点详图'],
  ['drawing-11', 'A-11二层办公室与阳台节点详图', 'A-11｜二层办公室与阳台节点详图'],
  ['drawing-12', 'A-12材料色彩与灯具选型控制图', 'A-12｜材料色彩与灯具选型控制图'],
];

const constructionControls = [
  ['保留项', '固定墙体、卫生间、室内门洞、楼梯、三级台阶和柱网不改动。'],
  ['空间安全', '机动区地台高差17cm，固定桌椅布置为临空边保留安全退距。'],
  ['运营设备', '品牌前厅保留双开门冰箱；阳台不放桌椅及储物，保留排水净空。'],
  ['现场签认', '定制家具、机电、灯具、门头与展陈下单前，按A-01清单完成复尺。'],
];
---

<header class="trail-project-hero">
  <div class="trail-project-hero__inner">
    <div class="trail-project-hero__brand">
      <img
        src={`${imageRoot}/brand-logo.webp`}
        alt="怪兽小太阳官方品牌标志"
        width="240"
        height="216"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div>
        <p class="trail-project-hero__kicker">Final Interior Design · Trail Running Brand Space</p>
        <h1>怪兽小太阳驿站设计</h1>
      </div>
    </div>
    <p class="trail-project-hero__lead">把办公、赛事、社群、展陈与对外营业，组织成一座真实可实施的山野品牌会客厅。</p>
    <div class="trail-project-hero__tags" aria-label="项目摘要">
      {projectSummary.map((item) => <span>{item}</span>)}
    </div>
  </div>
</header>

<main class="trail-project">
  <nav class="trail-project__toc" aria-label="文章目录">
    <a href="#overview">设计总览</a>
    <a href="#planning">空间规划</a>
    <a href="#renders">最终效果</a>
    <a href="#drawings">深化图册</a>
    <a href="#materials">材料落地</a>
    <a href="#signoff">施工签认</a>
  </nav>

  <section class="trail-project__section trail-project__intro" id="overview">
    <div>
      <p class="trail-project__eyebrow">Project Brief</p>
      <h2>一层向山野社群开放，二层让日常团队安静工作。</h2>
      <p>项目服务于怪兽小太阳越野跑赛事团队，容纳日常办公、赛事筹备、赞助商洽谈、跑者接待、品牌展陈，以及对外营业的“日咖夜酒”。</p>
      <p>二楼布置6个固定工位，一楼布置5个机动席位。设计以保留现状为前提，不移动固定墙体、卫生间、楼梯、三级台阶、柱网和室内门洞，在控制投入的同时建立完整的品牌体验。</p>
    </div>
    <div class="trail-project__facts" aria-label="项目数据">
      {projectFacts.map(([value, label]) => <div><strong>{value}</strong><span>{label}</span></div>)}
    </div>
  </section>

  <DesignImage
    baseName="drawing-01"
    alt="A-01怪兽小太阳山野会客厅最终设计总览与图纸目录"
    caption="A-01｜设计总览与图纸目录"
    fullHref="drawing-01-full.png"
    width={2000}
    height={1500}
    priority={true}
  />

  <section class="trail-project__section" id="planning">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Spatial Planning</p><h2>三条动线互不打架，公众体验与团队效率同时成立。</h2></div>
      <p>公众从沿街小门进入开放营业区；团队由一层机动区抵达二层办公室；赞助商从品牌正门进入，经品牌前厅和1m台盆过道抵达会议室。</p>
    </div>
    <div class="trail-project__routes">
      {designRoutes.map(([title, route]) => <article><h3>{title}</h3><p>{route}</p></article>)}
    </div>
    <div class="trail-project__drawing-grid">
      {planningDrawings.map((drawing) => (
        <DesignImage
          {...drawing}
          width={1800}
          height={1200}
          sizes="(max-width: 820px) calc(100vw - 32px), 570px"
        />
      ))}
    </div>
    <div class="trail-project__note-grid" aria-label="关键空间控制">
      <article><strong>品牌前厅 5.00×3.80m</strong><p>承担签到、赛事咨询与等候，保留现场双开门冰箱；左侧是固定墙体，不增设通往展厅的门。</p></article>
      <article><strong>赞助商会议室 5.80×2.80m</strong><p>8人日常舒适、10人峰值。98英寸屏幕置于右侧短墙，三级台阶、楼梯口与右侧过道保持畅通。</p></article>
      <article><strong>品牌展厅横跨小门2—4</strong><p>三处小门转为展示橱窗，固定墙展开赛事时间线；靠日咖夜酒的小门保留为日常通行入口。</p></article>
    </div>
  </section>

  <section class="trail-project__section" id="renders">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Final Visuals</p><h2>最终效果建立在现状结构、实测尺寸和运营需求之上。</h2></div>
      <p>效果图用于表达材质、灯光、家具和品牌氛围；墙体、门洞、台阶、过道、柱位及设备保留关系，以正式图纸和现场签认为准。</p>
    </div>
    <div class="trail-project__render-grid">
      {renders.map((render) => (
        <DesignImage
          {...render}
          fullHref={`${render.baseName}-1800.webp`}
          widths={[640, 1200, 1800]}
          sizes="(max-width: 820px) calc(100vw - 32px), 570px"
        />
      ))}
    </div>
  </section>

  <section class="trail-project__section" id="drawings">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Drawing Register</p><h2>A-01至A-12，构成完整的正式询价图册。</h2></div>
      <p>A-02与A-03明确总体家具及尺寸；A-04至A-12分别控制立面、节点、照明、强弱电、展陈、运营设备、二层办公室和材料选型。</p>
    </div>
    <div class="trail-project__drawing-grid">
      {technicalDrawings.map(([baseName, alt, caption]) => (
        <DesignImage
          baseName={baseName}
          alt={alt}
          caption={caption}
          fullHref={`${baseName}-full.png`}
          width={1800}
          height={1200}
          sizes="(max-width: 820px) calc(100vw - 32px), 570px"
        />
      ))}
    </div>
  </section>

  <section class="trail-project__section trail-project__materials" id="materials">
    <div>
      <p class="trail-project__eyebrow">Material &amp; Identity</p>
      <h2>怪兽蓝、太阳橙、保留灰砖、浅木与哑黑钢。</h2>
      <p>室内以山径等高线、赛道轨迹和赛事档案建立越野识别；模块化黑钢与浅木展陈家具便于赛季更新。照明以3000K暖光为主，高挑大厅利用分层轨道灯和重点照明控制尺度感。</p>
      <div class="trail-project__palette" aria-label="材料与颜色"><span>怪兽蓝</span><span>太阳橙</span><span>保留灰砖</span><span>浅木</span><span>暖白</span><span>哑黑钢</span></div>
    </div>
    <aside>
      <h3>高空间设计控制</h3>
      <p>一层大厅局部净高约6.76m，不以大面积吊顶压低空间；用悬挂展陈、分层照明和纵向品牌叙事充分利用高度，同时保留检修与消防条件。</p>
    </aside>
  </section>

  <section class="trail-project__section" id="signoff">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Construction Sign-off</p><h2>从设计成果进入询价、复尺与施工签认。</h2></div>
      <p>正式总包同时包含材料与定制家具清单、供应商报价表、工程量与预算分级清单、现场复尺清单及开业倒排计划。</p>
    </div>
    <div class="trail-project__controls">
      {constructionControls.map(([title, body], index) => <article><span>{String(index + 1).padStart(2, '0')}</span><div><h3>{title}</h3><p>{body}</p></div></article>)}
    </div>
  </section>

  <footer class="trail-project__closing">
    <p class="trail-project__eyebrow">Design Statement</p>
    <h2>让每一次到访，都从城市门口重新走向山野。</h2>
    <p>本页为怪兽小太阳驿站最终设计成果展示。施工放样与设备安装须以正式图纸、现场复尺、结构条件及相关专业签认结果为准。</p>
  </footer>
</main>
