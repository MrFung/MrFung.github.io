---
import DesignImage from './DesignImage.astro';
import '../styles/monsterSunStation.css';

const imageRoot = '/assets/img/monster-sun-station-design';

const projectFacts = [
  ['213.82㎡', '一层建筑面积'],
  ['61.93㎡', '二层建筑面积'],
