---
import "../styles/monsterSunStation.css";

const imageRoot = "/assets/img/monster-sun-station-design";

const projectFacts = [
  ["213.82㎡", "一层建筑面积"],
  ["61.93㎡", "二层建筑面积"],
  ["11席", "固定与机动工作席位"],
  ["8月16日", "计划对外营业"],
];

const projectSummary = [
  "项目类型｜越野跑品牌综合空间",
  "设计范围｜办公、展陈、接待与商业",
  "改造原则｜尊重现状、适度更新",
  "使用规模｜11人协同办公",
];

const designRoutes = [
  ["公众动线", "1号小门 → 日咖夜酒 → 山野会客厅 → 品牌展厅"],
  ["团队动线", "1号小门 → 机动项目区 → 二层6个固定工位"],
  ["赞助商动线", "品牌正门 → 品牌前厅 → 1m台盆过道 → 赞助商会议室"],
];

const facadeControls = [
  ["01", "小门1", "保留为唯一日常营业入口，用太阳橙标识咖啡、补给与夜间营业状态。"],
  ["02", "小门2—4", "不再承担通行，改成连续展陈橱窗，展示赛事里程碑、奖牌和商品。"],
  ["03", "品牌正门", "作为签到、赛事咨询和赞助商到达界面，两侧设置品牌故事与近期赛事信息。"],
  ["04", "二楼阳台", "不放桌椅，利用现有格栅内置太阳信标与2700K低亮线性灯。"],
];

const pendingItems = [
  "品牌展厅内净长宽、固定墙厚与精确定位",
  "赞助商会议室左侧宽门洞净宽及三级台阶尺寸",
  "给排水、排风、强弱电、消防与结构条件",
  "全部门洞、展墙、灯具与家具在施工前的现场复尺",
];
---

<header class="trail-project-hero">
  <div class="trail-project-hero__inner">
    <div class="trail-project-hero__brand">
      <img src={`${imageRoot}/brand-logo.jpg`} alt="怪兽小太阳赛事品牌标志" width="1080" height="969" />
      <div>
        <p class="trail-project-hero__kicker">Interior Design · Trail Running Brand Space</p>
        <h1>怪兽小太阳驿站设计</h1>
      </div>
    </div>
    <p class="trail-project-hero__lead">从拥挤的二楼办公室，变成一座能办公、会客、展陈与对外营业的越野品牌据点。</p>
    <div class="trail-project-hero__tags" aria-label="项目摘要">
      {projectSummary.map((item) => <span>{item}</span>)}
    </div>
  </div>
</header>

<main class="trail-project">
  <nav class="trail-project__toc" aria-label="文章目录">
    <a href="#overview">设计总览</a>
    <a href="#planning">空间规划</a>
    <a href="#meeting">会议室</a>
    <a href="#facade">沿街立面</a>
    <a href="#design-language">设计语言</a>
  </nav>

  <section class="trail-project__section trail-project__intro" id="overview">
    <div>
      <p class="trail-project__eyebrow">Project Brief</p>
      <h2>这里不是仓库，也不是住处，而是一座对山野社群开放的品牌会客厅。</h2>
      <p>怪兽小太阳是一家以越野跑赛事与山野社群为核心的团队。空间需要同时容纳日常办公、赛事筹备、赞助商洽谈、跑者接待、品牌展陈，以及对外营业的“日咖夜酒”。</p>
      <p>二楼完整设置6个固定安静工位，一楼承担公众体验、品牌展示和5个机动返场席位。固定墙体、卫生间、楼梯、三级台阶和室内门洞均保持现状，在控制改造投入的同时保留既有空间特征。</p>
    </div>
    <div class="trail-project__facts" aria-label="项目数据">
      {projectFacts.map(([value, label]) => <div><strong>{value}</strong><span>{label}</span></div>)}
    </div>
  </section>

  <figure class="trail-figure trail-figure--hero">
    <a href={`${imageRoot}/design-overview.png`} target="_blank" rel="noreferrer">
      <img src={`${imageRoot}/design-overview.png`} alt="怪兽小太阳山野会客厅空间设计图纸总览，包含一二层平面和沿街正立面" width="4800" height="3450" />
    </a>
    <figcaption>空间设计图纸总览。点击图片可查看原尺寸。</figcaption>
  </figure>

  <section class="trail-project__section" id="planning">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Spatial Strategy</p><h2>一层做体验，二层做专注。</h2></div>
      <p>把每天稳定到岗的人放到二楼，把返场、接待和项目协作留在一楼，既缓解拥挤，也让公众区域保持完整。</p>
    </div>

    <div class="trail-project__routes">
      {designRoutes.map(([title, route]) => <article><h3>{title}</h3><p>{route}</p></article>)}
    </div>

    <figure class="trail-figure">
      <a href={`${imageRoot}/space-plan.png`} target="_blank" rel="noreferrer">
        <img src={`${imageRoot}/space-plan.png`} alt="空间深化平面图，标注一层功能、二层工位、家具和主要尺寸" width="3600" height="2200" loading="lazy" />
      </a>
      <figcaption>空间深化平面：固定墙体和门洞按现状保留，家具尺寸为选型建议。</figcaption>
    </figure>
  </section>

  <section class="trail-project__section trail-project__space-story">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Exhibition &amp; Community</p><h2>品牌展厅不是一排柜子，而是一条可以被走完的赛事时间线。</h2></div>
      <p>展厅横跨沿街小门2—4，利用固定墙布置品牌历程、奖牌与纪念品；三座900×900mm可移动展台承接登山杖、越野袜、鱼灯包挂和竹笛等商品。</p>
    </div>
    <div class="trail-project__photo-grid">
      <figure class="trail-figure"><img src={`${imageRoot}/existing-exhibition.png`} alt="品牌展览厅现场，显示现有高挑空间和固定墙体" width="1600" height="1200" loading="lazy" /><figcaption>品牌展厅现状</figcaption></figure>
      <figure class="trail-figure"><img src={`${imageRoot}/existing-lounge.png`} alt="山野会客厅和座椅接待区现场" width="1600" height="1200" loading="lazy" /><figcaption>山野会客厅现状</figcaption></figure>
    </div>
    <div class="trail-project__callout">
      <strong>山野会客厅</strong>
      <p>承担选手接待、发布、分享与小型活动。双人座约1800×750mm，低柜兼作样品展示；高厅净高约6.76m，以可移动家具保持活动弹性。</p>
    </div>
  </section>

  <section class="trail-project__section" id="meeting">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Sponsor Meeting Room</p><h2>2.80×5.80m的狭长房间，日常8人舒适，10人作为峰值。</h2></div>
      <p>两张1600×800mm会议桌拼成3200×800mm长桌；98英寸屏幕放在图纸右侧短墙，所有席位观看角度比放在顶部长墙更均衡。</p>
    </div>
    <div class="trail-project__split">
      <figure class="trail-figure"><img src={`${imageRoot}/existing-meeting-room.png`} alt="赞助商会议室现场，左侧为宽门洞和三级台阶" width="1600" height="1200" loading="lazy" /><figcaption>现场：左侧宽门洞、三级台阶，室内无门扇</figcaption></figure>
      <figure class="trail-figure"><a href={`${imageRoot}/meeting-room-layout.png`} target="_blank" rel="noreferrer"><img src={`${imageRoot}/meeting-room-layout.png`} alt="赞助商会议室家具布置详图，显示十席、98英寸屏幕和楼梯口" width="3200" height="1900" loading="lazy" /></a><figcaption>会议室家具布置详图</figcaption></figure>
    </div>
    <ul class="trail-project__checklist">
      <li>桌边净空优先满足8人日常使用；峰值10人时使用两侧各5席。</li>
      <li>上二楼楼梯口1.10m保持畅通，靠楼梯一侧席位向右错开。</li>
      <li>从品牌正门进入会议室只能经1.00m台盆过道，品牌前厅左侧固定墙无门。</li>
    </ul>
  </section>

  <section class="trail-project__section" id="facade">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Street Facade</p><h2>四个小门和一个正门，要形成同一条沿街品牌叙事。</h2></div>
      <p>左侧四门照片标注段13m，右侧主入口照片标注段5m。保留灰砖、拱形比例和二楼格栅，用怪兽蓝、太阳橙、暖光和浅木做可逆更新。</p>
    </div>
    <div class="trail-project__facade-controls">
      {facadeControls.map(([index, title, body]) => <article><span>{index}</span><div><h3>{title}</h3><p>{body}</p></div></article>)}
    </div>
    <figure class="trail-figure">
      <a href={`${imageRoot}/facade-dimensions.png`} target="_blank" rel="noreferrer">
        <img src={`${imageRoot}/facade-dimensions.png`} alt="沿街主立面尺寸核对图，包含四个小门和右侧主入口" width="3600" height="2400" loading="lazy" />
      </a>
      <figcaption>沿街主立面尺寸核对。照片标注段与平面外轮廓口径不同，施工前必须复尺。</figcaption>
    </figure>
  </section>

  <section class="trail-project__section trail-project__balcony">
    <div class="trail-project__section-heading">
      <div><p class="trail-project__eyebrow">Second-floor Beacon</p><h2>二楼阳台不是多一个房间，而是整栋房子的远距离记忆点。</h2></div>
      <p>阳台面积3.68㎡，宽6.03m，反算进深约0.61m。阳台不设桌椅及储物设施，保留排水与维护净空。</p>
    </div>
    <figure class="trail-figure">
      <a href={`${imageRoot}/balcony-concept.png`} target="_blank" rel="noreferrer"><img src={`${imageRoot}/balcony-concept.png`} alt="二楼阳台太阳信标设计概念图" width="3200" height="1900" loading="lazy" /></a>
      <figcaption>格栅内侧设置品牌标识和耐候线性灯，不增加外挑易坠落构件。</figcaption>
    </figure>
  </section>

  <section class="trail-project__section trail-project__next" id="design-language">
    <div>
      <p class="trail-project__eyebrow">Design Language</p>
      <h2>怪兽蓝、太阳橙、保留灰砖、浅木与哑黑钢。</h2>
      <p>室内以山径等高线、赛道轨迹和奖牌墙建立越野识别；展陈家具采用黑钢与浅木模块，便于赛季更换内容。轨道灯以3000K暖光为主，重点展品单独打光。</p>
      <div class="trail-project__palette" aria-label="材料与颜色"><span>怪兽蓝</span><span>太阳橙</span><span>保留灰砖</span><span>浅木</span><span>暖白</span><span>哑黑钢</span></div>
    </div>
    <aside>
      <h3>深化与施工复核</h3>
      <ul>{pendingItems.map((item) => <li>{item}</li>)}</ul>
    </aside>
  </section>

  <footer class="trail-project__closing">
    <p class="trail-project__eyebrow">Design Statement</p>
    <h2>让办公、赛事、社群与日常营业，在同一座山野品牌空间中形成清晰而连贯的体验。</h2>
    <p>图纸用于设计表达；施工放样与设备安装以现场复尺、结构条件及相关专业确认结果为准。</p>
  </footer>
</main>
